// ============================================================
// PRISMA SCHEMA — LaserNet Portal Database
// Run: npx prisma migrate dev --name init
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS — Admin and client accounts
// ============================================================
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  password    String?  // bcrypt hash (legacy rows may still be plaintext — rehashed on next successful login)
  role        String   @default("client") // "client" | "admin"
  subrole     String?  // null | "sales" | "support" | "technician" — admin sub-specialization
  company     String?
  phone       String?
  photo       String?  @db.Text // base64 data URL or null
  language    String   @default("fr") // "fr" or "en"
  status      String   @default("invited") // "invited" | "active" | "disabled"
  inviteToken String?  @db.Text
  inviteExpiresAt DateTime?

  // Access schedule
  accessAlways    Boolean  @default(true)       // true = 24/7 access
  accessTimeFrom  String?                        // e.g. "08:00"
  accessTimeTo    String?                        // e.g. "17:00"
  accessDays      String?                        // JSON array e.g. ["mon","tue","wed","thu","fri"]
  accessDateFrom  DateTime?                      // access valid from this date
  accessDateTo    DateTime?                      // access valid until this date

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tickets     Ticket[] @relation("CreatedByUser")

  // CRM relations
  assignedLeads   Lead[]          @relation("LeadAssignee")
  loggedCalls     Call[]          @relation("CallLogger")
  receivedVisits  Visit[]         @relation("VisitReceiver")
  sentMessages    LeadMessage[]   @relation("MessageSender")
  leadActivities  LeadActivity[]  @relation("ActivityActor")
  improvements    Improvement[]   @relation("ImprovementCreator")
  createdMeetings ProjectMeeting[] @relation("MeetingCreator")
}

// ============================================================
// QUICKBOOKS TOKENS — Persistent OAuth token storage
// ============================================================
model QBToken {
  id           String   @id @default("singleton")
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  realmId      String
  expiresAt    BigInt
  updatedAt    DateTime @updatedAt
}

// ============================================================
// MANAGED CLIENTS — Clients imported from QuickBooks
// ============================================================
model ManagedClient {
  id        String   @id @default(cuid())
  addedAt   DateTime @default(now())

  // QuickBooks client data (cached locally)
  qbId          String  @unique
  displayName   String
  companyName   String
  email         String?
  phone         String?
  address       String?
  city          String?
  province      String?
  postalCode    String?

  // Relations
  contacts        Contact[]
  tickets         Ticket[]
  stations        Station[]
  machines        Machine[]
  trainingEvents  TrainingEvent[]
  leads           Lead[]
  visitGroups     VisitGroup[]
}

// ============================================================
// CONTACTS — Main contact + staff for a client
// Email is the stable natural ID (unique across the whole system).
// A contact belongs to ONE ManagedClient at a time; reassigning = updating managedClientId.
// ============================================================
model Contact {
  id              String        @id @default(cuid())
  managedClientId String
  managedClient   ManagedClient @relation(fields: [managedClientId], references: [id], onDelete: Cascade)

  name    String
  email   String  @unique
  phone   String?
  role    String?
  photo   String? @db.Text // base64 data URL or null
  type    String  // "maincontact" or "staff"  (legacy values: "responsible"/"employee" migrated via 20260413_rename_contact_type.sql)

  // Training fields
  trainingPhoto     String?  @db.Text // base64 of training booklet photo
  trainingInvoiceId String?  // QB invoice ID linked to training
  trainingCompleted Boolean  @default(false)

  // Soft-delete: null = active, set = archived timestamp
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// TICKETS — Support tickets
// ============================================================
model Ticket {
  id                  String   @id @default(cuid())
  ticketNumber        String   @unique
  managedClientId     String
  managedClient       ManagedClient @relation(fields: [managedClientId], references: [id], onDelete: Cascade)
  clientCompanyName   String

  // Who created it
  createdByUserId     String?
  createdByUser       User?    @relation("CreatedByUser", fields: [createdByUserId], references: [id])
  createdByName       String
  createdByEmail      String
  createdByRole       String

  subject     String
  description String   @db.Text
  priority    String   @default("medium") // critical, high, medium, low
  status      String   @default("open")   // open, in_progress, waiting, resolved, closed

  linkedInvoiceId     String?
  linkedInvoiceNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments TicketAttachment[]
}

// ============================================================
// TICKET ATTACHMENTS — Images/videos attached to tickets
// ============================================================
model TicketAttachment {
  id       String @id @default(cuid())
  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  name String
  type String // "image" or "video"
  url  String @db.Text // base64 data URL or file URL

  createdAt DateTime @default(now())
}

// ============================================================
// STATIONS — Central concept for machine programming
// (Renamed from "Job" on 2026-04-13 via 20260413_jobs_to_stations.sql)
// ============================================================
model Station {
  id              String   @id @default(cuid())
  stationNumber   String   @unique
  managedClientId String
  managedClient   ManagedClient @relation(fields: [managedClientId], references: [id], onDelete: Cascade)

  title       String
  notes       String?  @db.Text
  status      String   @default("draft") // "draft", "in_progress", "testing", "completed", "archived"

  // Deployment address. All NULL = fall back to ManagedClient billing address
  // ("use business address" in the UI). Set = custom install site.
  // `addressLocked` is a UI-side guardrail to prevent accidental edits once
  // the address has been verified on Street View / the map.
  addressLine    String?
  city           String?
  province       String?
  postalCode     String?
  country        String?
  addressLocked  Boolean  @default(false)

  // Physical computer deployed to run this station. Nullable: a Station can
  // exist before a PC is assigned (sold-but-not-shipped), and a PC can be
  // swapped without destroying the Station's history (§ station-pc model).
  stationPCId String?    @unique
  stationPC   StationPC? @relation(fields: [stationPCId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  invoices         StationInvoice[]
  machines         StationMachine[]
  robotPrograms    StationRobotProgram[]
  laserPresets     StationLaserPreset[]
  stateLog         MachineStateLog[]
}

// ============================================================
// STATION INVOICES — Links stations to QuickBooks invoices (main anchor)
// Also carries optional line-item selection metadata (8.4C).
// ============================================================
model StationInvoice {
  id           String @id @default(cuid())
  stationId    String
  station      Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  qbInvoiceId   String
  invoiceNumber String
  invoiceType   String @default("general") // "robot", "laser", "general", "service"
  amount        Float?
  linkedAt      DateTime @default(now())

  // Optional: JSON array of selected line items from the QB invoice
  //   [{ lineIndex: 0, description, quantity, amount, model? }, ...]
  // Null/absent = entire invoice is linked (legacy behaviour).
  lineItemsJson String? @db.Text

  // Machines sold on this invoice
  machines     Machine[]
}

// ============================================================
// STATION-MACHINE LINK — Many-to-many: which machines are in a station
// ============================================================
model StationMachine {
  id        String @id @default(cuid())
  stationId String
  station   Station @relation(fields: [stationId], references: [id], onDelete: Cascade)
  machineId String
  machine   Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@unique([stationId, machineId])
}

// ============================================================
// MACHINES — Individual tracked equipment (robots & lasers)
// ============================================================
model Machine {
  id              String   @id @default(cuid())
  serialNumber    String   @unique
  // Taxonomy (replaces legacy `type` column — migrated 2026-04-15):
  //   category     "robot"   | "accessory"
  //   subcategory  null       (for robots)
  //              | "laser" | "traditional_welding" | "sanding"   (for accessories)
  //   model        Robot : "E03" | "E05" | "E10" | "E12" | "E12+Rail3M" | "E12+Rail4M"
  //                Laser : "Cleaning" | "Welding"
  //                (others empty until defined)
  // The subcategory/model pair drives which UI/software interface the
  // machine routes into (robot app, Relfar controller, or none-yet).
  category        String   // "robot" | "accessory"
  subcategory     String?  // null for robots; see comment above for accessories
  model           String   // e.g. "E03", "Cleaning"
  nickname        String?  // optional friendly name

  // Network identity — MAC is the reliable identifier (survives IP changes,
  // AP-mode vs station-mode, DHCP reassignment). IP may drift; MAC doesn't.
  // Unique-if-set so we don't clobber on import when MAC isn't known yet.
  macAddress      String?  @unique
  ipAddress       String?

  // Physical location (for map)
  address         String?
  city            String?
  province        String?
  postalCode      String?
  country         String?  @default("Canada")
  latitude        Float?
  longitude       Float?

  // Status
  status          String   @default("active") // "active", "in_repair", "refunded", "decommissioned"

  // ---------- Licensing / kill-switch (§9.1, added 2026-04-13 session 3) ----------
  // licenseMode: "unlicensed" (default), "sold", "rented", "killed".
  //   sold     = runs indefinitely
  //   rented   = expires at expiresAt
  //   killed   = kill-switch flipped, robot refuses operation immediately
  licenseMode        String    @default("unlicensed")
  expiresAt          DateTime? // null for sold/unlicensed; set for rented
  killSwitchActive   Boolean   @default(false)
  // When the robot last successfully fetched its license from the portal.
  licenseLastCheckedAt DateTime?
  // --------------------------------------------------------------------------------

  // Current owner
  managedClientId String?
  managedClient   ManagedClient? @relation(fields: [managedClientId], references: [id], onDelete: SetNull)

  // Original invoice this machine was sold on
  invoiceId       String?
  invoice         StationInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  events          MachineEvent[]
  stations        StationMachine[]
  robotPrograms   StationRobotProgram[]
  laserPresets    StationLaserPreset[]
  stateLog        MachineStateLog[]
}

// ============================================================
// STATION PC — The physical computer deployed to a client site.
// Separate from Station (the commercial line) and Machine (the robot/laser).
// Rationale: PCs are fungible — a dead PC can be swapped without invalidating
// the Station or re-invoicing the client. Keeping them distinct also lets us
// track "which PCs are alive" (last heartbeat) independent of contract state.
// One-to-one with Station (today) via Station.stationPCId.
// ============================================================
model StationPC {
  id           String   @id @default(cuid())
  // Deployment identifier (e.g. "COBOTDSM-001"). Matches the ROBOT_SERIAL
  // env var set on the PC's robot service. Primary key for the robot-side
  // heartbeat, license fetch, and sync channels.
  serial       String   @unique
  macAddress   String?  @unique
  hostname     String?  // OS hostname reported by the PC
  nickname     String?  // admin-friendly label
  installedAt  DateTime @default(now())

  // Software stack running on the PC. Populated by heartbeat.
  robotVersion   String?
  relfarVersion  String?
  lastHeartbeatAt DateTime?
  lastHeartbeatIp String?
  // Operator-entered LAN IP of the PC (e.g. "192.168.1.42"). Used to build
  // same-LAN links to the robot (port 8080) and relfar (port 5000) software
  // UIs. Superseded later by a Cloudflare Tunnel hostname per PC.
  localIp         String?

  // Status — what the admin sees at a glance.
  //   "provisioning" — created in Portal, hasn't checked in yet
  //   "online"       — heartbeat within threshold
  //   "offline"      — no heartbeat beyond threshold
  //   "retired"      — decommissioned, kept for history
  status       String   @default("provisioning")

  // Quarantine flag for self-registered PCs. A PC created via
  // POST /api/station-pcs/register starts with approved=false and
  // heartbeats from it are accepted (to populate versions/IP) but it stays
  // visually flagged in the admin UI until an operator clicks "Approve".
  // PCs created manually via the admin page are approved=true by default.
  approved      Boolean  @default(false)

  notes        String?  @db.Text

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Back-relation to the Station currently running on this PC (if any).
  station      Station?

  // Assign/detach audit trail — every time this PC is bound to or released
  // from a Station we append a row. Survives Station deletion (see
  // StationPCAssignment.stationId — no FK, with a snapshot of number/title).
  assignments  StationPCAssignment[]
}

// ============================================================
// STATION PC ASSIGNMENT HISTORY
// One row per assign/detach of a StationPC to/from a Station. Captures
// the actor (best-effort from auth cookie) and the reason so Hugo can
// trace who moved a PC where and why.
// ============================================================
model StationPCAssignment {
  id            String   @id @default(cuid())
  stationPCId   String
  stationPC     StationPC @relation(fields: [stationPCId], references: [id], onDelete: Cascade)

  // The Station involved. Nullable because 'detached' events outlive the
  // Station row when a station is deleted. We snapshot number+title below
  // so the UI stays readable post-delete.
  stationId     String?
  stationNumber String?
  stationTitle  String?

  action        String   // 'assigned' | 'detached'
  reason        String?  // 'manual' | 'station_deleted' | 'reassigned' | 'pc_retired' | ...

  actorEmail    String?
  actorName     String?

  note          String?
  createdAt     DateTime @default(now())

  @@index([stationPCId])
  @@index([stationId])
}

// ============================================================
// MACHINE EVENTS — Full lifecycle history for each machine
// ============================================================
model MachineEvent {
  id          String   @id @default(cuid())
  machineId   String
  machine     Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)

  eventType   String   // "installed", "repair", "refund", "model_change", "reassigned", "relocated"
  notes       String?  @db.Text

  // For reassignment events
  fromClientId String?
  toClientId   String?

  // For relocation events
  fromAddress  String?
  toAddress    String?
  fromIp       String?
  toIp         String?

  createdAt   DateTime @default(now())
  createdBy   String?  // admin user who made the change
}

// ============================================================
// STATION ROBOT PROGRAMS — Saved robot pathways/programs
// ============================================================
model StationRobotProgram {
  id          String @id @default(cuid())
  stationId   String
  station     Station @relation(fields: [stationId], references: [id], onDelete: Cascade)
  machineId   String?
  machine     Machine? @relation(fields: [machineId], references: [id], onDelete: SetNull)

  name           String
  description    String? @db.Text
  status         String  @default("development") // "development", "testing", "production", "archived"
  dxfFilename    String?
  dxfData        String? @db.Text
  waypoints      String? @db.Text // JSON array of waypoints

  // Motion parameters
  speed          Float @default(50.0)
  acceleration   Float @default(100.0)
  blendRadius    Float @default(0.5)

  // Origin coordinates (mm, mm, mm)
  originX        Float @default(400.0)
  originY        Float @default(0.0)
  originZ        Float @default(200.0)

  // Orientation (degrees)
  orientationRx  Float @default(180.0)
  orientationRy  Float @default(0.0)
  orientationRz  Float @default(0.0)

  // Approach height (mm)
  approachHeight Float @default(20.0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
}

// ============================================================
// STATION LASER PRESETS — Saved laser controller configurations
// ============================================================
model StationLaserPreset {
  id          String @id @default(cuid())
  stationId   String
  station     Station @relation(fields: [stationId], references: [id], onDelete: Cascade)
  machineId   String?
  machine     Machine? @relation(fields: [machineId], references: [id], onDelete: SetNull)

  name        String
  description String? @db.Text
  status      String  @default("development") // "development", "testing", "production", "archived"

  // Laser controller settings
  registers   String @db.Text // JSON object of register address→value pairs
  port        String?
  baudRate    Int?
  parity      String?
  slaveId     Int?
  rs485Mode   String @default("normal")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
}

// ============================================================
// MACHINE STATE LOG — Historical logging of robot/laser state
// ============================================================
model MachineStateLog {
  id        String @id @default(cuid())
  stationId String?
  station   Station? @relation(fields: [stationId], references: [id], onDelete: SetNull)
  machineId String?
  machine   Machine? @relation(fields: [machineId], references: [id], onDelete: SetNull)

  source    String // "robot" or "laser"
  data      String @db.Text // JSON blob of state snapshot
  timestamp DateTime @default(now())
}

// ============================================================
// TRAINING SYSTEM
// ============================================================

// Training templates — reusable training definitions (Settings)
model TrainingTemplate {
  id          String @id @default(cuid())
  name        String // e.g. "Laser Training", "Cobot Training"
  description String @db.Text
  files       TrainingFile[]
  events      TrainingEvent[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Training files — PDFs, videos, docs attached to templates
model TrainingFile {
  id         String @id @default(cuid())
  templateId String?
  template   TrainingTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String
  fileType   String // "pdf", "video", "image", "other"
  fileData   String @db.Text // base64 data or URL
  fileSize   Int?   // size in bytes
  createdAt  DateTime @default(now())

  // Files can also be attached to events directly
  eventId    String?
  event      TrainingEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// Training events — scheduled trainings (Agenda)
model TrainingEvent {
  id              String @id @default(cuid())
  templateId      String?
  template        TrainingTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  managedClientId String?
  managedClient   ManagedClient? @relation(fields: [managedClientId], references: [id], onDelete: SetNull)
  title           String
  description     String?  @db.Text
  date            DateTime
  duration        Int?     // duration in minutes
  status          String   @default("scheduled") // scheduled, completed, cancelled

  attendees   TrainingAttendee[]
  files       TrainingFile[]
  visitGroups VisitGroup[]       // auto-created visit groups for this training day

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Training attendees — staff linked to training events
model TrainingAttendee {
  id            String @id @default(cuid())
  eventId       String
  event         TrainingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  contactId     String
  name          String
  email         String
  inviteSent    Boolean  @default(false)
  inviteSentAt  DateTime?
  confirmed     Boolean  @default(false)
  confirmedAt   DateTime?
  createdAt     DateTime @default(now())

  @@unique([eventId, contactId])
}

// QB data cache — store invoices and customers locally
model QBCache {
  id        String   @id @default("singleton")
  invoices  String   @db.Text // JSON array of all invoices
  customers String   @db.Text // JSON array of all customers
  cachedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// LOCAL BUSINESSES — Non-QB businesses (prospects not yet in QuickBooks)
// Added 2026-04-16: Editable business profiles for walk-in visitors
// ============================================================
model LocalBusiness {
  id          String   @id @default(cuid())
  name        String
  address     String?
  city        String?
  province    String?
  postalCode  String?
  country     String?  @default("Canada")
  phone       String?
  email       String?
  website     String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  visitGroups VisitGroup[]
  leads       Lead[]
}

// ============================================================
// VISIT GROUPS — Groups multiple visitors arriving together
// Links to a business (ManagedClient or LocalBusiness) and tracks
// the overall visit lifecycle: active → completed → follow-up sent.
// ============================================================
model VisitGroup {
  id              String   @id @default(cuid())

  // Custom display name (editable by admin)
  displayName     String?

  // Link to business (at most one of these)
  managedClientId String?
  managedClient   ManagedClient? @relation(fields: [managedClientId], references: [id], onDelete: SetNull)
  localBusinessId String?
  localBusiness   LocalBusiness? @relation(fields: [localBusinessId], references: [id], onDelete: SetNull)

  // Main contact from the group (lead ID)
  mainContactId   String?

  // Status
  status          String   @default("active") // "active" | "completed"
  notes           String?  @db.Text

  expectedFollowUpAt DateTime?
  completedAt     DateTime?
  summarySentAt   DateTime?  // when summary was emailed to main contact

  // Training link — when auto-created from a TrainingEvent
  trainingEventId String?
  trainingEvent   TrainingEvent? @relation(fields: [trainingEventId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  visits          Visit[]
  files           VisitFile[]
  needs           VisitNeed[]

  @@index([status])
  @@index([managedClientId])
  @@index([localBusinessId])
  @@index([trainingEventId])
}

// ============================================================
// VISIT FILES — Photos, documents, files attached to a visit group
// ============================================================
model VisitFile {
  id              String   @id @default(cuid())
  visitGroupId    String
  visitGroup      VisitGroup @relation(fields: [visitGroupId], references: [id], onDelete: Cascade)

  fileName        String
  fileType        String   // "image" | "document" | "video" | "other"
  fileData        String   @db.Text // base64 data URL or file URL
  fileSize        Int?     // bytes

  uploadedById    String?
  notes           String?

  createdAt       DateTime @default(now())

  @@index([visitGroupId])
}

// ============================================================
// VISIT NEEDS — What visitors expect from the visit
// Salesperson checks these off during/after the visit; each has
// a status and optional expected delivery date.
// ============================================================
model VisitNeed {
  id              String   @id @default(cuid())
  visitGroupId    String
  visitGroup      VisitGroup @relation(fields: [visitGroupId], references: [id], onDelete: Cascade)

  // "info" | "quote" | "manual" | "photos" | "videos" | "reports" | "other"
  type            String
  description     String?  @db.Text
  status          String   @default("pending") // "pending" | "in_progress" | "sent" | "completed"
  expectedDate    DateTime?
  completedAt     DateTime?

  assignedToId    String?
  notes           String?  @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([visitGroupId])
}

// ============================================================
// CRM — LEADS, CALLS, VISITS, MESSAGES
// Added 2026-04-16: Sales pipeline & walk-in registration system
// ============================================================

// A lead is any person/company entering the sales funnel —
// walk-in, inbound call, outbound call, referral, or web inquiry.
// May link to an existing ManagedClient (returning buyer) or stand alone (new prospect).
model Lead {
  id              String   @id @default(cuid())

  // Link to existing client (null = new prospect)
  managedClientId String?
  managedClient   ManagedClient? @relation(fields: [managedClientId], references: [id], onDelete: SetNull)

  // Link to local business (non-QB prospect)
  localBusinessId String?
  localBusiness   LocalBusiness? @relation(fields: [localBusinessId], references: [id], onDelete: SetNull)

  // Contact info (always populated, even if linked to ManagedClient)
  name            String
  email           String?
  phone           String?
  phone2          String?    // secondary phone
  company         String?
  otherContacts   String?  @db.Text // free-text: other people to reach
  photo           String?  @db.Text // selfie from kiosk (base64 data URL)

  // Pipeline
  stage           String   @default("new")
  // Stages: new → qualified → demo_scheduled → demo_done → quote_sent → negotiation → won | lost
  source          String   // walk_in, inbound_call, outbound_call, referral, web

  // Sales context
  callbackReason  String?  @db.Text // why we need to call this person back
  objective       String?  @db.Text // what the client wants to achieve
  budget          Float?             // average budget
  productsOfInterest String? @db.Text // JSON array of QB item IDs/names

  // Assignment
  assignedToId    String?
  assignedTo      User?    @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Sales data
  estimatedValue  Float?
  nextFollowUpAt  DateTime?
  wonAt           DateTime?
  lostAt          DateTime?
  lostReason      String?

  notes           String?  @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  calls           Call[]
  visits          Visit[]
  messages        LeadMessage[]
  activities      LeadActivity[]
  projects        LeadProject[]
  meetingAttendances MeetingAttendee[]

  @@index([managedClientId])
  @@index([localBusinessId])
  @@index([assignedToId])
  @@index([stage])
  @@index([nextFollowUpAt])
}

// A phone call — inbound or outbound — linked to a lead.
model Call {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  loggedById      String?
  loggedBy        User?    @relation("CallLogger", fields: [loggedById], references: [id], onDelete: SetNull)

  type            String   // "inbound" | "outbound"
  clientType      String   @default("new") // "existing" | "new" — did the caller already buy?
  duration        Int?     // seconds
  notes           String?  @db.Text
  outcome         String?  // "reached" | "no_answer" | "voicemail" | "callback_scheduled"

  calledAt        DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([leadId])
}

// A walk-in visit registered at the kiosk (or logged manually by staff).
model Visit {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Group visit (null = solo visitor)
  visitGroupId    String?
  visitGroup      VisitGroup? @relation(fields: [visitGroupId], references: [id], onDelete: SetNull)

  // Self-registered info from kiosk
  visitorName     String
  visitorEmail    String?
  visitorPhone    String?
  visitorCompany  String?
  visitorPhoto    String?  @db.Text // selfie (base64 data URL)

  // Who received them
  receivedById    String?
  receivedBy      User?    @relation("VisitReceiver", fields: [receivedById], references: [id], onDelete: SetNull)

  purpose         String?  // "inquiry" | "demo" | "meeting" | "service" | "other"
  notes           String?  @db.Text

  visitedAt       DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([leadId])
}

// Messages on a lead thread — salesperson ↔ client, all logged.
// Client messages arrive via unique link (no portal login needed).
model LeadMessage {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Internal user who sent (null when client sends via unique link)
  senderId        String?
  sender          User?    @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)

  // Denormalized for display (client name when isFromClient=true)
  senderName      String
  senderEmail     String?
  isFromClient    Boolean  @default(false)

  content         String   @db.Text
  subject         String?

  sentAt          DateTime @default(now())

  @@index([leadId])
}

// Audit trail: every meaningful event on a lead.
model LeadActivity {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  actorId         String?
  actor           User?    @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorName       String?

  // "stage_change" | "note" | "call_logged" | "visit_logged" | "message_sent" | "assignment_change"
  type            String
  description     String   @db.Text

  // For stage changes
  fromStage       String?
  toStage         String?

  createdAt       DateTime @default(now())

  @@index([leadId])
}

// ============================================================
// PROJECTS & QUOTES — Sales pipeline under Leads
// Each Lead has ≥1 LeadProject. Each project can have multiple
// quotes. Each quote has line items that can be individually
// accepted / removed.
// ============================================================

model LeadProject {
  id                  String   @id @default(cuid())
  leadId              String
  lead                Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  name                String   // e.g. "Laser cleaning system — warehouse"
  status              String   @default("active") // "active" | "won" | "lost" | "on_hold"
  notes               String?  @db.Text

  // Project-specific sales fields (override lead-level defaults)
  callbackReason      String?            // reason for this specific project
  suggestedProducts   String?  @db.Text  // JSON array of product names
  objective           String?
  budget              Float?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  quotes              Quote[]
  meetings            ProjectMeeting[]

  @@index([leadId])
}

// ============================================================
// PROJECT MEETINGS — Scheduled meetings linked to a project
// ============================================================
model ProjectMeeting {
  id              String   @id @default(cuid())
  projectId       String
  project         LeadProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title           String
  scheduledAt     DateTime
  durationMinutes Int      @default(60)
  location        String?          // e.g. "Office", "Zoom", address
  notes           String?  @db.Text
  status          String   @default("scheduled") // "scheduled" | "completed" | "cancelled"

  createdById     String?
  createdBy       User?    @relation("MeetingCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendees       MeetingAttendee[]

  @@index([projectId])
  @@index([scheduledAt])
}

// ============================================================
// MEETING ATTENDEES — People invited to a project meeting
// ============================================================
model MeetingAttendee {
  id              String   @id @default(cuid())
  meetingId       String
  meeting         ProjectMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  // Link to a lead (contact)
  leadId          String?
  lead            Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  // Or free-text name (for external people not in the system)
  name            String?
  email           String?

  status          String   @default("invited") // "invited" | "confirmed" | "declined" | "attended"

  createdAt       DateTime @default(now())

  @@unique([meetingId, leadId])
  @@index([meetingId])
  @@index([leadId])
}

model Quote {
  id              String   @id @default(cuid())
  projectId       String
  project         LeadProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  quoteNumber     String?          // human-readable quote reference (e.g. "Q-2026-042")
  status          String   @default("pending") // "pending" | "accepted" | "refused"
  notes           String?  @db.Text

  // Set when this quote was duplicated from another
  parentQuoteId   String?

  sentAt          DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  expiresAt       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           QuoteItem[]

  @@index([projectId])
}

model QuoteItem {
  id              String   @id @default(cuid())
  quoteId         String
  quote           Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  description     String             // line item description
  quantity        Float    @default(1)
  unitPrice       Float    @default(0)
  unit            String?            // "each" | "hour" | "month" | etc.
  notes           String?  @db.Text
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([quoteId])
}

// ============================================================
// IMPROVEMENTS — Problem-solving & feature tracking
// ============================================================
model Improvement {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  priority    String   @default("medium")   // "critical" | "high" | "medium" | "low"
  status      String   @default("new")      // "new" | "in_progress" | "done" | "dismissed"
  createdById String
  createdBy   User     @relation("ImprovementCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([priority])
}

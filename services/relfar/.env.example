# Relfar V4 dashboard configuration
# Copy this to .env and edit the values for this station.
# NSSM does not inherit the shell environment, so this file is how the
# RelfarBridge service learns its per-station configuration.

# ---------------------------------------------------------------------------
# Deployment pattern: DUAL-HOMED STATION PC (AP mode)
# ---------------------------------------------------------------------------
# The station PC connects to TWO networks at once:
#   - Ethernet  -> business LAN (internet, portal sync)
#   - WiFi      -> Relfar's own AP (SSID "RDWelder", password "12345678")
#
# In this setup the Relfar controller is ALWAYS at 192.168.1.5 (firmware-
# fixed AP gateway), and the station PC is at 192.168.1.x on its WiFi NIC.
# This avoids DHCP drift and the flaky station-mode TCP bridge on the
# HF-LPB100 WiFi module.
#
# Don't forget to flag the RDWelder WiFi profile as auto-connect:
#   netsh wlan set profileparameter name="RDWelder" connectionmode=auto
# ---------------------------------------------------------------------------

# IP of the Relfar controller. Default 192.168.1.5 (AP mode, always fixed).
# Override if this station is wired to a different controller address.
RELFAR_HOST=192.168.1.5

# Local NIC to bind outgoing TCP socket to. Set to the station PC's WiFi
# interface IP (usually 192.168.1.2 when dual-homed with RDWelder AP) so
# Windows doesn't route Relfar traffic out the Ethernet adapter.
# Leave blank to let Windows auto-pick (works on single-NIC machines).
RELFAR_BIND=192.168.1.2

# Controller TCP port. Default 123. Rarely needs changing.
# RELFAR_PORT=123

# Poll interval in seconds for the cleaning parameter block.
# RELFAR_POLL=0.5

# Relfar V4 dashboard configuration
# Copy this to .env and edit the values for this station.
# NSSM does not inherit the shell environment, so this file is how the
# RelfarBridge service learns its per-station configuration.

# IP of the controller on this station's network. Leave blank to require
# user to click "Find controller" in the web UI on every boot.
RELFAR_HOST=

# Local NIC to bind outgoing TCP socket to. Leave blank to let Windows
# auto-pick the interface. Set this only if your PC is multi-homed and
# Windows picks the wrong adapter (e.g. lab AP + home WiFi both on the
# same 192.168.1.0/24).
RELFAR_BIND=

# Controller TCP port. Default 123. Rarely needs changing.
# RELFAR_PORT=123

# Poll interval in seconds for the cleaning parameter block.
# RELFAR_POLL=0.5

# ===========================================
# Portal Configuration
# ===========================================
DATABASE_URL=postgresql://user:pass@localhost:5432/lasernet
JWT_SECRET=change-this-in-production
JWT_EXPIRATION=7d

# QuickBooks Integration
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:3000/api/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox

# ===========================================
# Service URLs (Portal uses these)
# ===========================================
ROBOT_SERVICE_URL=http://localhost:8080
RELFAR_SERVICE_URL=http://localhost:5000

# ===========================================
# Robot Service Configuration
# ===========================================
ROBOT_IP=192.168.10.10
ROBOT_PORT=10003
ROBOT_TIMEOUT=30

# ===========================================
# Relfar Service Configuration
# ===========================================
RELFAR_DEFAULT_PORT=COM5
RELFAR_BAUD_RATE=115200

# ===========================================
# General Configuration
# ===========================================
NODE_ENV=development
PYTHON_ENV=development
LOG_LEVEL=info
